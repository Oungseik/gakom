{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@repo/org-db",
  "type": "module",
  "private": true,
  "scripts": {
    "with-env": "dotenv -e ../../.env --",
    "check": "biome check --write .",
    "build": "tsdown",
    "check-types": "tsc --noEmit",
    "db:push": "bun --bun run with-env drizzle-kit push",
    "db:studio": "bun --bun run with-env drizzle-kit studio",
    "db:generate": "bun --bun run with-env drizzle-kit generate",
    "db:migrate": "bun run with-env drizzle-kit migrate"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@tursodatabase/api": "^1.9.2",
    "@tursodatabase/database": "^0.5.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "1.0.0-beta.17-67b1795"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/bun": "^1.3.10",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "1.0.0-beta.17-67b1795",
    "drizzle-seed": "^0.3.1",
    "tsdown": "0.21.2",
    "typescript": "^5.9.3"
  }
}
