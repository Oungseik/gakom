{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@repo/config",
  "type": "module",
  "private": true,
  "scripts": {
    "with-env": "dotenv -e ../../.env --",
    "check": "biome check --write .",
    "build": "tsdown",
    "check-types": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./country": {
      "types": "./src/country.ts",
      "default": "./src/country.ts"
    },
    "./timezone": {
      "types": "./src/timezone.ts",
      "default": "./src/timezone.ts"
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "tsdown": "0.21.2",
    "typescript": "^5.9.3"
  }
}
